<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Back up preferences (settings) but exclude models and database -->
        <include domain="sharedpref" path="." />
        <exclude domain="database" path="." />
        <exclude domain="file" path="models" />
    </cloud-backup>
    <device-transfer>
        <!-- Allow transferring preferences and progress on device-to-device -->
        <include domain="sharedpref" path="." />
        <include domain="database" path="." />
        <exclude domain="file" path="models" />
    </device-transfer>
</data-extraction-rules>
